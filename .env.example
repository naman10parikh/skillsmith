# Energy Platform — Environment Variables
# Copy to .env and fill in your keys

# Claude Code / Anthropic
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# E2B (Firecracker microVM sandboxes)
# Get at: https://e2b.dev/dashboard
E2B_API_KEY=e2b_...
E2B_AGENT_TEMPLATE=energy-agent

# Clerk (Authentication — SSO, OAuth, Phone)
# Get at: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe (Payments & Subscriptions)
# Get at: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Places (Venue search for agents)
# Get at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=AIza...

# Ticketmaster (Event search — free, 5000 calls/day)
# Get at: https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
TICKETMASTER_API_KEY=...

# Composio (Google Workspace — Gmail, Calendar, Sheets, Docs with managed OAuth)
# Get at: https://composio.dev — Free tier: 5K calls/mo
# COMPOSIO_API_KEY=...

# Supabase (Postgres — memory persistence, traces, conversations)
# Get at: https://supabase.com/dashboard → New Project → Settings → API
# Run supabase/migrations/001_user_memories.sql in the SQL Editor after creating the project.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Optional: bypasses RLS, use for server-side only

# GitHub PAT (for Actions push + MCP)
# Also add as GitHub repo secret named PAT_TOKEN:
# https://github.com/naman10parikh/Energy/settings/secrets/actions/new
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Web Search — Claude's native web_search tool uses ANTHROPIC_API_KEY ($10/1K searches)
# No separate key needed. Brave/Tavily are optional budget fallbacks.
# BRAVE_API_KEY=...
# TAVILY_API_KEY=...

# Twilio (SMS + Voice — instant setup)
# Get at: https://console.twilio.com (Account SID + Auth Token on dashboard)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# WhatsApp Cloud API (Direct via Meta — 3-10 days for verification)
# Get at: https://developers.facebook.com/ → WhatsApp product → API Setup
# WHATSAPP_ACCESS_TOKEN=...
# WHATSAPP_PHONE_NUMBER_ID=...
# WHATSAPP_BUSINESS_ACCOUNT_ID=...
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=...

# Cronofy (Unified Calendar — Google + Outlook + Apple)
# Get at: https://app.cronofy.com/sign_up/developer
# CRONOFY_CLIENT_ID=...
# CRONOFY_CLIENT_SECRET=...

# Browserbase (Stagehand cloud browsers + MCP)
# Get at: https://www.browserbase.com/dashboard
BROWSERBASE_API_KEY=bb_...
BROWSERBASE_PROJECT_ID=...

# Firecrawl (Web scraping & crawling MCP)
# Get at: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-...

# Spark Agent Identity (Phase 1: manual, Phase 2: semi-auto, Phase 3: autonomous)
# SPARK_EMAIL=spark@energy-app.com
# SPARK_EMAIL_PASSWORD=...
# SPARK_TWILIO_NUMBER=+1...
# SPARK_INSTAGRAM_USERNAME=sparkbyenergy
# SPARK_INSTAGRAM_PASSWORD=...
# SPARK_TIKTOK_USERNAME=sparkbyenergy
# SPARK_TIKTOK_PASSWORD=...

# Agent Format Extension (configurable — currently .energy)
AGENT_FORMAT_EXTENSION=.energy

# Server
PORT=3001
HOST=0.0.0.0
AGENTS_DIR=agents
DB_PATH=data/energy.db
